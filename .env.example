# AssetManager - Environment Variables
# Copy this file to .env and modify values for production

# Application
APP_NAME="AssetManager"
DEBUG=true
ENV=development  # Set to "production" in production

# Database
DATABASE_URL="sqlite:///./asset_manager.db?mode=wal"

# JWT Authentication
SECRET_KEY="your-secret-key-change-in-production"  # Required in production
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp"
MAX_IMAGE_WIDTH=800
MAX_IMAGE_HEIGHT=800
MAX_IMAGE_SIZE_KB=100

# Niutrans Translation API (for chemical name translation)
NIUTRANS_APPID=""
NIUTRANS_APIKEY=""

# Default Admin (required)
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD=""  # Required - set a secure password
DEFAULT_ADMIN_FULL_NAME="系统管理员"

